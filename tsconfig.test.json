{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "node18",
    "moduleResolution": "node16",
    "types": ["jest", "@testing-library/jest-dom", "node"]
  },
  "include": ["src"],
  // Un-inherit tsconfig.json's exclude so test files belong to this project
  // (needed for ESLint's type-aware parsing; ts-jest ignores include/exclude).
  "exclude": []
}

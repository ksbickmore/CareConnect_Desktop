{
  "name": "careconnect",
  "version": "1.0.0",
  "description": "CareConnect (CarpalTunnel Focus) electron desktop application",
  "keywords": [
    "careconnect",
    "electron",
    "carpaltunnel",
    "npm",
    "node"
  ],
  "homepage": "https://github.com/ksbickmore/CareConnect_Desktop#readme",
  "bugs": {
    "url": "https://github.com/ksbickmore/CareConnect_Desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksbickmore/CareConnect_Desktop.git"
  },
  "license": "MIT",
  "author": "Kristopher Bickmore <ksbickmore@gmail.com>",
  "type": "commonjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "prestart": "npm run models",
    "start": "electron-forge start",
    "predev": "npm run models",
    "dev": "electron-forge start",
    "models": "node scripts/fetch-models.mjs",
    "clean": "node -e \"const{rmSync}=require('fs');for(const d of['.vite','out'])rmSync(d,{recursive:true,force:true})\"",
    "prepackage": "npm run clean && npm run models",
    "package": "electron-forge package",
    "premake": "npm run clean && npm run models",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@huggingface/transformers": "^3.8.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}

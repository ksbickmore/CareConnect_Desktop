{
  "name": "careconnect",
  "version": "1.0.0",
  "description": "CareConnect (CarpalTunnel Focus) electron desktop application",
  "keywords": [
    "careconnect",
    "electron",
    "carpaltunnel",
    "npm",
    "node"
  ],
  "homepage": "https://github.com/ksbickmore/CareConnect_Desktop#readme",
  "bugs": {
    "url": "https://github.com/ksbickmore/CareConnect_Desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ksbickmore/CareConnect_Desktop.git"
  },
  "license": "MIT",
  "author": "Kristopher Bickmore <ksbickmore@gmail.com>",
  "type": "commonjs",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "clean": "node -e \"const{rmSync}=require('fs');for(const d of['.vite','out'])rmSync(d,{recursive:true,force:true})\"",
    "prepackage": "npm run clean",
    "package": "electron-forge package",
    "premake": "npm run clean",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.0.20",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
